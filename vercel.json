{
  "version": 2,
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "has": [
        {
          "type": "host",
          "value": "app.seoranktrackingtool.com"
        }
      ],
      "source": "/(.*)",
      "destination": "/apps/app/dist/$1"
    },
    {
      "has": [
        {
          "type": "host",
          "value": "seoranktrackingtool.com"
        }
      ],
      "source": "/(.*)",
      "destination": "/apps/website/dist/$1"
    },
    {
      "has": [
        {
          "type": "host",
          "value": "www.seoranktrackingtool.com"
        }
      ],
      "source": "/(.*)",
      "destination": "/apps/website/dist/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/website/dist/$1"
    }
  ]
}